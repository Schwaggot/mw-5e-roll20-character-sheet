# Set the default behavior for all files
* text=auto

# Force LF line endings for text files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.txt text eol=lf
*.svg text eol=lf

# Treat image and binary files as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.pdf binary
*.zip binary

# Normalize line endings for shell scripts
*.sh text eol=lf

# Ensure config files are treated as text
*.config text eol=lf
*.conf text eol=lf

# Diff settings for specific file types
*.css diff=css
*.js diff=js